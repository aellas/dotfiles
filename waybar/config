{
    "layer": "top",

    "position": "top",


    "modules-left": [ 
        "hyprland/workspaces",
        "hyprland/window"
    ],
    
    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "custom/updates",
        "temperature",
        "wireplumber",
        "custom/logout",
        "custom/shutdown"

    ],

    
    "custom/updates": {
    "exec": ".config/waybar/modules/updates.sh",
    "interval": 3600,
    "on-click": "kitty $echo sudo pacman -Syuu"
    },

    "hyprland/window": {
	    "format": "  {title}",
 		"max-length": 333,
	    "seperate-outputs": true
  },

  "clock": {
	"format": "<span foreground='#ffffff'> </span><span>  {:%I:%M %p  }</span>  ",
	"tooltip-format": "{calendar}",
	  "calendar": {
		"mode"          : "month",
		"mode-mon-col"  : 3,
		"on-scroll"     : 1,
		"on-click-right": "mode",
		"format": {
		  "months":     "<span color='#ffead3'><b>{}</b></span>",
		  "days":       "<span color='#ecc6d9'><b>{}</b></span>",
		  "weeks":      "<span color='#99ffdd'><b>{%W}</b></span>",
		  "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
		  "today":      "<span color='#ff6699'><b>{}</b></span>"
			  }
		  },
   "actions": {
	 "on-click-middle": "mode",
	 "on-click-right": "shift_up",
		"on-click": "shift_down"	   
   }
},


    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        "format": "<span foreground='#FFFFFF'>󰋋</span>  {volume}% ",
        "format-muted": " ",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "headphone": " ",
            "hands-free": " ",
            "headset": " ",
            "phone": " ",
            "portable": " ",
            "car": " ",
            "default": [" ", " ", " "]
        }
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format": "<span></span>  {temperatureC}°C",
        "interval": 1
    },

    "disk": {
        "interval": 30,
        "format": "  {percentage_free}%"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    },

    "custom/logout": {
        "format": "        ",
        "tooltip": false,
        "on-click": "hyprctl dispatch exit"
    },

    "custom/shutdown": {
        "format": "           ",
        "tooltip": false,
        "on-click": "wlogout --protocol layer-shell"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "icon-size": 2,
        "format-icons": {
          "active": "",
          "default": "•",
          "persistent": "•"
        },
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "all-outputs": false,
        "persistent_workspaces": {
          "*": 4
      }
  }
}
